# ============================================================
# SDIH Talleres — Variables de entorno
# Copiá este archivo a .env.local y completá los valores reales.
# Nunca commitees .env.local ni reemplaces los valores en este archivo.
# ============================================================

# --- Supabase ---
# Dashboard: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY
# Service role: solo para scripts admin / API routes seguras. NUNCA exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# --- Resend (emails transaccionales) ---
# Dashboard: https://resend.com/api-keys
RESEND_API_KEY=re_YOUR_API_KEY
RESEND_FROM_EMAIL=talleres@salazardukeimpacthubteams.com

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
